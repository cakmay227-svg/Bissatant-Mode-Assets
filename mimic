local function updateLasers()
    for i = 1, TOTAL_MODELS do
        local laser = laserParts[i]
        local currentModel = modelList[i]
        local nextModel = modelList[(i % TOTAL_MODELS) + 1]
        
        if laser and currentModel and nextModel and currentModel.PrimaryPart and nextModel.PrimaryPart then
            local p1 = currentModel.PrimaryPart.Position
            local p2 = nextModel.PrimaryPart.Position
            local distance = (p1 - p2).Magnitude
            laser.Size = Vector3.new(distance, 0.2, 0.2)
            laser.CFrame = CFrame.new((p1 + p2) / 2, p2) * CFrame.Angles(0, math.pi / 2, 0)
        end
    end
end

local function playWinAnimation()
    playSmoothFlash()

    if entitySound then
        entitySound:Stop()
        entitySound:Destroy()
    end

    for _, model in ipairs(modelList) do
        if model ~= realModelInstance then
            model:Destroy()
        end
    end
    for _, laser in ipairs(laserParts) do
        if laser then laser:Destroy() end
    end

    if realModelInstance then
        local particles = {}
        local originalRates = {}

        for _, desc in ipairs(realModelInstance:GetDescendants()) do
            if desc:IsA("ParticleEmitter") then
                table.insert(particles, desc)
                originalRates[desc] = desc.Rate
            end
        end

        local fadeDuration = 1.5
        local fadeTimer = 0
        local fadeConnection
        
        fadeConnection = RunService.Heartbeat:Connect(function(dt)
            fadeTimer = fadeTimer + dt
            local progress = math.clamp(fadeTimer / fadeDuration, 0, 1)

            for _, p in ipairs(particles) do
                p.Rate = originalRates[p] * (1 - progress)
                p.Transparency = NumberSequence.new(math.clamp(progress, 0, 1))
            end

            if fadeTimer >= fadeDuration then
                fadeConnection:Disconnect()
                mimicFolder:Destroy()
            end
        end)
    else
        mimicFolder:Destroy()
    end
end

local angle = 0
local currentRadius = 0         
local spawnPhaseDuration = 1.2  
local spawnTimer = 0
local holdTimer = 0

local isSpawning = true      
local isHolding = false       
local isRotating = false      
local gameFinished = false

local isLookingAtReal = false
local rotateConnection
local spawnDirection = rootPart.CFrame.LookVector

rotateConnection = RunService.Heartbeat:Connect(function(dt)
    if gameFinished then return end 
    if not rootPart or not rootPart.Parent then 
        rotateConnection:Disconnect()
        return 
    end
    
    local centerPos = rootPart.Position
    local targetCenter
    
    if isSpawning then
        spawnTimer = spawnTimer + dt
        local progress = math.clamp(spawnTimer / spawnPhaseDuration, 0, 1)
        currentRadius = 0 + (MAX_RADIUS - 0) * (1 - (1 - progress) * (1 - progress))
        
        if spawnTimer >= 0.1 then
            for _, m in ipairs(modelList) do
                for _, desc in ipairs(m:GetDescendants()) do
                    if desc:IsA("BasePart") and desc:GetAttribute("OriginalTransparency") then
                        desc.Transparency = desc:GetAttribute("OriginalTransparency")
                    end
                end
            end
        end
        
        if spawnTimer >= spawnPhaseDuration then
            isSpawning = false
            isHolding = true 
            setupPhysicalLasers() 
        end
        
        targetCenter = centerPos + (spawnDirection * 4)
        
    elseif isHolding then
        holdTimer = holdTimer + dt
        if holdTimer >= SPAWN_HOLD_TIME then
            isHolding = false
            isRotating = true 
        end
        targetCenter = centerPos
        currentRadius = MAX_RADIUS
        
    elseif isRotating then
        targetCenter = centerPos
        currentRadius = MAX_RADIUS
        
        local speedStep = isLookingAtReal and (ROTATION_SPEED * 0.5) or ROTATION_SPEED
        angle = angle + (speedStep * dt)
    end
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Include
    raycastParams.FilterDescendantsInstances = {mimicFolder}
    
    local raycastResult = Workspace:Raycast(camera.CFrame.Position, camera.CFrame.LookVector * 100, raycastParams)
    local lookedAtModel = nil
    
    if raycastResult and raycastResult.Instance then
        lookedAtModel = raycastResult.Instance:FindFirstAncestorOfClass("Model")
    end
    
    for i, model in ipairs(modelList) do
        if model and model.PrimaryPart and model.Parent then
            local modelAngle = angle + (i * (math.pi * 2 / TOTAL_MODELS))
            local offsetX = math.cos(modelAngle) * currentRadius
            local offsetZ = math.sin(modelAngle) * currentRadius
            
            local targetPos = targetCenter + Vector3.new(offsetX, 0.5, offsetZ) 
            local lookAtPlayerCFrame = CFrame.new(targetPos, Vector3.new(centerPos.X, targetPos.Y, centerPos.Z))
            
            model:SetPrimaryPartCFrame(lookAtPlayerCFrame)
            
            local isBeingLookedAt = (model == lookedAtModel)
            for _, desc in ipairs(model:GetDescendants()) do
                if desc:IsA("BasePart") then
                    local baseSize = originalSizes[desc]
                    if baseSize then
                        desc.Size = isBeingLookedAt and (baseSize * 1.4) or baseSize
                    end
                end
            end
        end
    end
    
    if not isSpawning and #laserParts > 0 and laserParts[1].Parent then
        updateLasers()
    end
end)

