end

local function setupPhysicalLasers()
    for i = 1, TOTAL_MODELS do
        local laser = Instance.new("Part")
        laser.Name = "Tráº­nPhÃ¡pLaserTÃ­m_" .. i
        laser.Material = Enum.Material.Neon
