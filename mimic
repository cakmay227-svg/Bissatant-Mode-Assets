local function playSmoothFlash()
    local cc = Lighting:FindFirstChild("MainColorCorrection") or Lighting:FindFirstChildWhichIsA("ColorCorrectionEffect")
    if not cc then 
        return 
    end
    
    local oldColor = cc.TintColor
    local oldContrast = cc.Contrast
    
    local flashInfo = TweenInfo.new(0.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
    
    local tweenIn = TweenService:Create(cc, flashInfo, {
        TintColor = Color3.fromRGB(170, 0, 255),
        Contrast = 5
    })
    
    local tweenOut = TweenService:Create(cc, flashInfo, {
        TintColor = oldColor,
        Contrast = oldContrast
    })
    
    tweenIn:Play()
    tweenIn.Completed:Connect(function()
        tweenOut:Play()
    end)
end

playSmoothFlash()

local function loadModel(assetId, name, hideInitially)
    local success, objects = pcall(function() return game:GetObjects(assetId) end)
    if success and objects and objects[1] then
        local model = objects[1]
        model.Name = name
        if not model.PrimaryPart then
            local primary = model:FindFirstChildWhichIsA("BasePart")
            if primary then model.PrimaryPart = primary end
        end
        
        for _, desc in ipairs(model:GetDescendants()) do
            if desc:IsA("BasePart") then
                desc.Anchored = true
                desc.CanCollide = false
                originalSizes[desc] = desc.Size 
                
                if hideInitially then
                    desc:SetAttribute("OriginalTransparency", desc.Transparency)
                    desc.Transparency = 1
                end
            end
        end
        return model
    end
    return nil
end

for i = 1, TOTAL_MODELS do
