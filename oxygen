local _, modelSize = model:GetBoundingBox()

local function getSpawnPosition()

	for _ = 1, 100 do

		local floor = floors[math.random(1, #floors)]

		local floorSize = floor.Size
		local floorPos = floor.Position

		local x = floorPos.X + (math.random() - 0.5) * (floorSize.X * 0.8)
		local z = floorPos.Z + (math.random() - 0.5) * (floorSize.Z * 0.8)

		local y =
			floor.Position.Y +
			(floor.Size.Y / 2) +
			(modelSize.Y / 2) +
			1.5

		local candidate = Vector3.new(x, y, z)

		local overlap = workspace:GetPartBoundsInBox(
			CFrame.new(candidate),
			modelSize
		)

		local blocked = false

		for _, part in ipairs(overlap) do

			if part:IsDescendantOf(model) then
				continue
			end

			if part.Name ~= "Floor" then
				blocked = true
				break
			end
		end

		if not blocked then
			return candidate
		end
	end

	return nil
end

