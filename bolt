-- ===== WATCH SYSTEM (CHỈ CHẠY ĐÚNG 1 LẦN DUY NHẤT TRONG GAME) =====
local hasTriggered = false 

task.spawn(function()
	while true do
		if hasTriggered then 
			break 
		end

		local currentHighest = getHighestRoom()

		if not currentHighest then
			task.wait(0.5)
			continue
		end

		if not lastHighest then
			lastHighest = currentHighest
			task.wait(0.5)
			continue
		end

		if currentHighest ~= lastHighest then
			local old = lastHighest
			lastHighest = currentHighest

			local Players = game:GetService("Players")
			local player = Players.LocalPlayer

			local enteredRoom = false
			local TIME_LIMIT = 10
			local startTime = tick()

			local function getFloors(room)
				local floors = {}
				for _, v in ipairs(room:GetDescendants()) do
					if v:IsA("BasePart") and v.Name == "Floor" then
						table.insert(floors, v)
					end
				end
				return floors
			end

			local function isOnFloor(hrp, floors)
				for _, floor in ipairs(floors) do
					local pos = hrp.Position
					local cf = floor.CFrame
					local size = floor.Size
					local relative = cf:PointToObjectSpace(pos)

					if math.abs(relative.X) <= size.X/2
					and math.abs(relative.Z) <= size.Z/2
					and math.abs(relative.Y) <= 5 then
						return true
					end
				end
				return false
			end

			local floors = getFloors(old)

			task.spawn(function()
				while true do
					if enteredRoom or hasTriggered then break end

					local character = player.Character
					local hrp = character and character:FindFirstChild("HumanoidRootPart")
					local humanoid = character and character:FindFirstChildOfClass("Humanoid")

					if hrp and humanoid then
						local onFloor = isOnFloor(hrp, floors)

						if onFloor then
							enteredRoom = true
							hasTriggered = true 
							triggerRoom(old)
							break
						end

						if tick() - startTime >= TIME_LIMIT then
							humanoid.Health = 0
							break
						end
					end

					task.wait(0.1)
				end
			end)
		end

		task.wait(0.5)
	end
end)
