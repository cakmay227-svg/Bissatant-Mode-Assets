-- lấy room số cao nhất
local function getHighestRoom()
	local highestRoom = nil
	local highestNumber = -math.huge 

	for _, room in ipairs(CurrentRooms:GetChildren()) do 
		local num = tonumber(room.Name) 
		if num and num > highestNumber then 
			highestNumber = num 
			highestRoom = room 
		end
	end

	return highestRoom 
end

-- ===== HÀM DO DỌN DẸP PHÒNG CŨ =====
local function cleanOldRoom(highestRoom)
	if not highestRoom then return end 

	local assets = highestRoom:FindFirstChild("Assets") 
	if assets then 
		for _, obj in ipairs(assets:GetDescendants()) do 
			if obj:IsA("Model") and (obj.Name == "Rafter" or obj.Name == "Chandelier") then 
				obj:Destroy() 
			end
		end
	end

	local parts = highestRoom:FindFirstChild("Parts") 
	if parts then 
		for _, obj in ipairs(parts:GetDescendants()) do 
			if obj:IsA("Model") and (obj.Name == "DropCeiling" or obj.Name == "Rafter") then 
				obj:Destroy() 
			end
		end
	end

	for _, obj in ipairs(highestRoom:GetDescendants()) do 
		if obj:IsA("ParticleEmitter")
			or obj:IsA("Trail")
			or obj:IsA("Beam")
			or obj:IsA("Smoke")
			or obj:IsA("Fire")
			or obj:IsA("Sparkles")
			or obj:IsA("PointLight")
			or obj:IsA("SpotLight")
			or obj:IsA("SurfaceLight") then 

			obj:Destroy() 

		elseif obj:IsA("BasePart") and obj.Material == Enum.Material.Neon then 
			obj.Transparency = 1 
		end
	end
end

-- ===== SPAWN FUNCTION =====
local function spawnAtDoor(room, door)
	if not boltSystemActive then return end

	local success, objects = pcall(function()
		return game:GetObjects("rbxassetid://" .. MODEL_ID) 
	end)

	if not success or not objects or not objects[1] then return end 

	local obj = objects[1] 
	obj.Parent = workspace 
	table.insert(spawnedObjects, obj)

	local model =
		obj:IsA("Model")
		and obj
		or obj:FindFirstChildWhichIsA("Model", true) 

	if not model then return end 

	for _, v in ipairs(model:GetDescendants()) do 
		if v:IsA("BasePart") then 
			v.Anchored = true 
		end
	end

	local cf = door.CFrame 
	local finalCF = cf * CFrame.new(0, 0, -1.5) 
	local startCF = finalCF * CFrame.new(0, -15, 0) 

	local cfValue = Instance.new("CFrameValue") 
	cfValue.Value = startCF 

	local conn
	conn = cfValue:GetPropertyChangedSignal("Value"):Connect(function() 
		if model and model.Parent then 
			model:PivotTo(cfValue.Value) 
		else
			if conn then conn:Disconnect() end 
		end
	end)

	model:PivotTo(startCF) 
	
	task.wait(0.2) 
	if not boltSystemActive then if cfValue then cfValue:Destroy() end return end

	local tween = TweenService:Create( 
		cfValue,
		TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), 
		{ Value = finalCF } 
	)

	tween:Play() 
end

