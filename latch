local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local camera = workspace.CurrentCamera

local player = Players.LocalPlayer

local function getCharacter()
	return player.Character or player.CharacterAdded:Wait()
end

local function lockSpeedLoop(humanoid)
	local running = true

	task.spawn(function()
		while running and humanoid.Parent do
			humanoid.WalkSpeed = 0
			task.wait()
		end
	end)

	return function()
		running = false
	end
end

local latestRoom = ReplicatedStorage
	:WaitForChild("GameData")
	:WaitForChild("LatestRoom")
	.Value

local currentRoom = workspace.CurrentRooms:FindFirstChild(tostring(latestRoom))
if not currentRoom then
	warn("Current room not found:", latestRoom)
	return
end

local wardrobes = {}

for _, obj in ipairs(currentRoom:GetDescendants()) do
	if obj:IsA("Model") and obj.Name == "Wardrobe" then

		local hasAnimExit = obj:FindFirstChild("Anim_Exit", true)
		local hasAnimEnter = obj:FindFirstChild("Anim_EnterModel", true)

		-- Chỉ lấy Wardrobe chưa có cả 2 animation
		if not hasAnimExit and not hasAnimEnter then
			table.insert(wardrobes, obj)
		end
	end
end

if #wardrobes == 0 then
	warn("No wardrobes found in room", latestRoom)
	return
end

local wardrobe = wardrobes[math.random(#wardrobes)]

local hidePrompt = wardrobe:FindFirstChild("HidePrompt", true)
local main = wardrobe:FindFirstChild("Main", true)

local animExit = wardrobe:FindFirstChild("Anim_Exit", true)
if not animExit then
	animExit = Instance.new("Animation")
	animExit.Name = "Anim_Exit"
	animExit.AnimationId = "rbxassetid://18759987341"
	animExit.Parent = wardrobe
end

local animEnterModel = wardrobe:FindFirstChild("Anim_EnterModel", true)
if not animEnterModel then
	animEnterModel = Instance.new("Animation")
	animEnterModel.Name = "Anim_EnterModel"
	animEnterModel.AnimationId = "rbxassetid://9460435404"
	animEnterModel.Parent = wardrobe
end

if not (hidePrompt and main and animExit and animEnterModel) then
	warn("Required objects missing in wardrobe")
	return
end

