	-- Footsteps
	local footsteps = rush:FindFirstChild("Footsteps")
	if footsteps then
		footsteps:Destroy()
	end

	-- Main sound
	local playSound = rush:FindFirstChild("PlaySound")
	if playSound and playSound:IsA("Sound") then
		playSound.Volume = 3
		playSound.Looped = false
		playSound.SoundId = "rbxassetid://89150933160076" 
		playSound.RollOffMaxDistance = 100
		playSound.RollOffMinDistance = 1
	end

	-- Particle texture
	for _, v in ipairs(att:GetDescendants()) do
		if v:IsA("ParticleEmitter") then
			v.Texture = "rbxassetid://72273242031698"
			v.Size = NumberSequence.new(4)
		end
	end

	-- Remove indicate
	local indicate = rush:FindFirstChild("indicate")
	if indicate then
		indicate:Destroy()
	end

	-- Lấy tất cả PointLight
	local pointLights = {}

	for _, v in ipairs(att:GetChildren()) do
		if v:IsA("PointLight") then
			table.insert(pointLights, v)
		end
	end

	-- Nếu model có 3 PointLight giống như m nói
	if #pointLights >= 3 then
		-- Giữ cái đầu tiên
		pointLights[2]:Destroy()
		pointLights[3]:Destroy()

		pointLights[1].Brightness = 0.3
		pointLights[1].Range = 10
		pointLights[1].Color = Color3.fromRGB(255,255,255)
	elseif #pointLights >= 1 then
		-- Fallback
		pointLights[1].Brightness = 0.3
		pointLights[1].Range = 10
		pointLights[1].Color = Color3.fromRGB(255,255,255)
	end

	-- Cố định mọi part để không bị văng
	for _, v in ipairs(entity:GetDescendants()) do
		if v:IsA("BasePart") then
			v.Anchored = true
			v.CanCollide = false
			v.Massless = true
		end
	end

	-- Vị trí chính giữa Wood
	local spawnCF = wood.CFrame * CFrame.new(0, -2.5, 3.2)

	if entity:IsA("Model") then

		if not entity.PrimaryPart then
			local pp = entity:FindFirstChildWhichIsA("BasePart", true)
			if pp then
				entity.PrimaryPart = pp
			end
		end

		if entity.PrimaryPart then
			entity:PivotTo(spawnCF)
		end

	elseif entity:IsA("BasePart") then
		entity.CFrame = spawnCF
	end

end)

