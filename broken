local CurrentRooms = workspace:WaitForChild("CurrentRooms")
local burnedParts = {}

local function GetRandomPart(obj)
	if obj:IsA("BasePart") then
		return obj
	elseif obj:IsA("Model") then
		if obj.PrimaryPart then
			return obj.PrimaryPart
		else
			return obj:FindFirstChildWhichIsA("BasePart", true)
		end
	end
end

local function CanRotate(obj)
	if obj:IsA("Model") then
		local name = obj.Name

		if name == "Door"
		or name == "KeyObtain"
		or name == "DropCeiling" then
			return false
		end
	end

	return true
end

local function GetHeat(part)
	local size = part.Size.Magnitude
	return math.clamp(math.floor(size / 3), 5, 10)
end

local function RemoveHalfLights(room)
	local lights = {}

	for _, v in ipairs(room:GetDescendants()) do
		if v:IsA("PointLight")
			or v:IsA("SpotLight")
			or v:IsA("SurfaceLight") then
			table.insert(lights, v)
		end
	end

	local amount = math.floor(#lights / 2)

	for i = 1, amount do
		local index = math.random(#lights)
		local light = table.remove(lights, index)

		if light then
			light:Destroy()
		end
	end
end

local function CanBeBurned(part)
	if not part then
		return false
	end

	if part.Name == "Floor" then
		return false
	end

	if part.Name == "Wall" then
		return false
	end

	if part:IsA("MeshPart") and part.Name == "Door" then
		return false
	end

	return true
end

local function AddFire(room)
	if room.Name == "50" then
		return
	end

	local objects = {}

	for _, v in ipairs(room:GetDescendants()) do
		if v:IsA("BasePart") or v:IsA("Model") then
			local p = GetRandomPart(v)

			if p
				and CanBeBurned(p)
				and not table.find(objects, v) then
				table.insert(objects, v)
			end
		end
	end

	if #objects == 0 then
		return
	end

	local amount = math.clamp(
		math.floor(#objects / 8),
		3,
		math.floor(#objects / 2)
	)

	for i = 1, math.min(amount, #objects) do
		local index = math.random(#objects)
		local obj = table.remove(objects, index)
		local part = GetRandomPart(obj)

		if part and not part:FindFirstChild("RandomFire") then
			if CanRotate(obj) then
	if obj:IsA("Model") then
		for _, v in ipairs(obj:GetDescendants()) do
			if v:IsA("BasePart") then
				v.Anchored = false
			end
		end
	elseif part:IsA("BasePart") then
		part.Anchored = false
	end
end

