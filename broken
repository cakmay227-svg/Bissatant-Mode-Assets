for _, room in ipairs(CurrentRooms:GetChildren()) do
	if room:IsA("Model") and room.Name ~= "50" then
		task.spawn(function()
			RemoveHalfLights(room)

			if math.random(1, 100) <= 40 then
				AddFire(room)
			end
		end)
	end
end

CurrentRooms.ChildAdded:Connect(function(room)
	if room:IsA("Model") and room.Name ~= "50" then
		task.wait(0.1)

		RemoveHalfLights(room)

		if math.random(1, 100) <= 40 then
			AddFire(room)
		end
	end
end)
