function startChase()
	if not model or not model.Parent then return end
	if chasing then return end
	chasing = true

	local root = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart", true)
	if not root then return end

	chaseThread = task.spawn(function()
		while chasing and model and model.Parent and hum and hum.Health > 0 do

			if postMissLock then
				hum.WalkSpeed = 0
				hum.JumpPower = 0
			end

			local targetPos = hrp.Position

			local tween = TweenService:Create(
				root,
				TweenInfo.new(3.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
				{Position = targetPos}
			)

			tween:Play()
			tween.Completed:Wait()

			-- check hit REAL collision
			if (root.Position - hrp.Position).Magnitude < 3.5 then
			onDeath()
				hum.Health = 0

				-- cleanup final
				postMissLock = false
				chasing = false

				if model then model:Destroy() end
				if cc then cc:Destroy() end
				if overlayGui then overlayGui:Destroy() end

				break
			end

			task.wait(0.1)
		end
	end)
end

