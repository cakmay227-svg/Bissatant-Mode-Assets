local function cameraShake(intensity, duration)
	local start = tick()
	local originalCF = camera.CFrame

	local conn
	conn = RunService.RenderStepped:Connect(function()
		if tick() - start > duration then
			camera.CFrame = originalCF
			conn:Disconnect()
			return
		end

		local offsetX = (math.random() - 0.5) * intensity
		local offsetY = (math.random() - 0.5) * intensity
		local offsetZ = (math.random() - 0.5) * intensity

		camera.CFrame = originalCF * CFrame.new(offsetX, offsetY, offsetZ)
	end)
end

